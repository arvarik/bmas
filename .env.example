# ─────────────────────────────────────────────────────────────────────
# bMAS — Environment Variables
# ─────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# This file is loaded by Docker Compose. NEVER commit .env to git.

# ── Required ───────────────────────────────────────────────────────

# Redis password (used by all services that connect to Redis)
REDIS_PASSWORD=changeme

# LiteLLM master key (authenticates requests from daemon → LiteLLM)
LITELLM_MASTER_KEY=sk-changeme

# Shared bearer secret for node↔daemon authentication (doc 03 §4).
# All node and daemon HTTP surfaces require this.
# Generate with: openssl rand -hex 32
BMAS_NODE_KEY=

# ── Cloud API Keys (add the ones you use) ──────────────────────────
# At least one is required unless routing everything to local models.

GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ── Optional ───────────────────────────────────────────────────────

# Comma-separated list of IPs/hostnames for Next.js dev server access.
# Required when accessing Mission Control from a LAN IP other than localhost.
# ALLOWED_DEV_ORIGINS=192.168.1.100,my-dev-host.local

# ── Local Triage Backend (optional) ────────────────────────────────
# These are only needed when triage.backend is set to "local" in bmas.yaml.
# The default "gemini" backend uses GEMINI_API_KEY above — no extra config.

# Hugging Face token (for downloading gated Qwen3 model)
# HF_TOKEN=

# vLLM container overrides (must match bmas.yaml triage section)
# TRIAGE_MODEL=Qwen/Qwen3-1.7B
# TRIAGE_GPU_MEMORY=0.35
# TRIAGE_MAX_MODEL_LEN=8192

# ── Monitoring (Beszel) ────────────────────────────────────────────
# Credentials for the Beszel Hub (PocketBase). Required for hardware
# telemetry (CPU, RAM, thermals) on the Infrastructure page.
# These are the email/password you use to log into the Beszel web UI.
# The Hub URL itself is configured in bmas.yaml under monitoring.beszel_hub.

# BESZEL_EMAIL=
# BESZEL_PASSWORD=
