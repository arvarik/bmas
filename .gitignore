# ─────────────────────────────────────────────────────────────────────
# bMAS — Blackboard Multi-Agent System
# Root .gitignore
# ─────────────────────────────────────────────────────────────────────

# ── Environment & Secrets ──────────────────────────────────────────
.env
.env.*
*.pem
bmas.yaml

# ── Python ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.venv/
venv/
*.egg

# ── Node / Next.js ─────────────────────────────────────────────────
node_modules/
.next/
out/
build/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
*.tsbuildinfo
next-env.d.ts
.vercel

# ── Docker (compose overrides, volumes) ────────────────────────────
docker-compose.override.yml

# ── Redis (dump files) ─────────────────────────────────────────────
dump.rdb
appendonly.aof
redis/data/

# ── SQLite (local-dev database) ────────────────────────────────────
# When running the daemon outside Docker (bare uvicorn), set
# BMAS_DB_PATH=./.data/bmas.db to store the DB locally.
.data/
*.db
*.db-wal
*.db-shm

# ── LiteLLM (runtime data) ────────────────────────────────────────
litellm/data/

# ── Triage (model cache) ──────────────────────────────────────────
triage/data/
triage/cache/

# ── OS / Editor ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/

# ── Debug Logs ─────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Coverage & Testing ────────────────────────────────────────────
coverage/
.nyc_output/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/

# ── Eval Results (per-run benchmark output) ────────────────────────
eval/results/*.jsonl
eval/results/*_summary.json
eval/results/ab_*.md
eval/results/failure_*.jsonl
pr10.diff
mission-control/public/ci-verify-input.json

# ── Editor, Agent, & Local Temporary Files ────────────────────────
.agent/
.agents/
.obsidian/
*.log
*.local.yaml
*.local.yml
docs/proposals/
docs/roadmap/

# ── Ad-hoc Scripts (personal utilities, not project-relevant) ─────
scripts/generate_icons.py
scripts/rebuild.sh


